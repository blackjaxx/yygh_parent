# =============================================================================
# cupr / 尚医通 — 本地开发环境变量
# 使用: cp .env.example .env  然后按需修改
# =============================================================================

# --- 基础设施（与 docker-compose.yml 一致）---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USERNAME=root
# 已轮换的本地开发密码（勿用于生产；生产请使用强密码）
MYSQL_ROOT_PASSWORD=yygh_dev_mysql_2026
MYSQL_PASSWORD=yygh_dev_mysql_2026

MONGO_HOST=127.0.0.1
MONGO_PORT=27017

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=yygh_dev_rabbit_2026

NACOS_SERVER_ADDR=127.0.0.1:8848

# --- API 网关 ---
GATEWAY_PORT=8080

# --- 用户端回调地址 ---
YYGH_BASE_URL=http://localhost:3000

# --- 微信开放平台（登录）— 请在开放平台重新申请后填写 ---
WX_OPEN_APP_ID=REPLACE_WITH_YOUR_WX_OPEN_APP_ID
WX_OPEN_APP_SECRET=REPLACE_WITH_YOUR_WX_OPEN_APP_SECRET
WX_OPEN_REDIRECT_URL=http://guli.shop/api/ucenter/wx/callback

# --- 微信支付 — 请在商户平台重新申请后填写 ---
WEIXIN_APPID=REPLACE_WITH_YOUR_WEIXIN_APPID
WEIXIN_PARTNER=REPLACE_WITH_YOUR_MERCHANT_ID
WEIXIN_PARTNERKEY=REPLACE_WITH_YOUR_MERCHANT_KEY
WEIXIN_CERT_PATH=yygh/service/service_order/src/main/resources/cert/apiclient_cert.p12

# --- 阿里云短信 ---
ALIYUN_SMS_REGION_ID=default
ALIYUN_SMS_ACCESS_KEY_ID=REPLACE_WITH_YOUR_ALIYUN_ACCESS_KEY_ID
ALIYUN_SMS_SECRET=REPLACE_WITH_YOUR_ALIYUN_SECRET

# --- 腾讯云短信（可选）---
SMS_QCLOUD_APP_ID=
SMS_QCLOUD_APP_KEY=
SMS_QCLOUD_TEMPLATE_ID=
SMS_QCLOUD_SIGN=

# --- 阿里云 OSS ---
ALIYUN_OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
ALIYUN_OSS_ACCESS_KEY_ID=REPLACE_WITH_YOUR_OSS_ACCESS_KEY_ID
ALIYUN_OSS_SECRET=REPLACE_WITH_YOUR_OSS_SECRET
ALIYUN_OSS_BUCKET=REPLACE_WITH_YOUR_BUCKET
